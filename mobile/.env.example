# Cognure mobile environment variables.
# Copy this file to `.env` and fill in the values, then run `npx expo start`.
# All must be prefixed EXPO_PUBLIC_ so Expo inlines them into the app bundle.

# Base URL of the deployed Cognure web app that hosts the API routes
# (e.g. https://your-cognure-app.vercel.app). No trailing slash.
EXPO_PUBLIC_API_URL=

# Supabase project URL and anon key — the SAME project the web app uses.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
